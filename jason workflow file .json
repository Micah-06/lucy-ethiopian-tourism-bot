      "parameters": {
        "public": true,
        "initialMessages": "🌍 Welcome to Lucy – Ethiopian Tourism Assistant!\n\nI can help with:\n\n🏛️ Attractions\n🏨 Hotels\n🍽️ Restaurants\n🚌 Transportation\n🛂 Visa Information\n🚨 Emergency Contacts\n🗺️ Travel Planning\n\nI also support multiple languages:\n🇬🇧 English\n🇪🇹 አማርኛ\n🇪🇹 Afaan Oromo\n🇪🇹 ትግርኛ\n🇸🇦 العربية\n\nHow can I help you explore Ethiopia today?",
        "options": {
          "inputPlaceholder": "Ask about Ethiopia...",
          "subtitle": "Discover Ethiopia's attractions, hotels, restaurants, transportation, visa information and travel tips.",
          "title": "Lucy - Ethiopian Tourism Assistant"
        }
      },
